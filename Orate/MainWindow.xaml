<Window x:Class="Orate.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orate" Height="650" Width="900"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#08000000">
            <ListBox x:Name="Nav" BorderThickness="0" Background="Transparent"
                     Padding="8,16" SelectionChanged="OnNavChanged">
                <ListBoxItem Content="Home" Padding="12,10" />
                <ListBoxItem Content="Settings" Padding="12,10" />
            </ListBox>
        </Border>

        <!-- Detail -->
        <ContentControl x:Name="Detail" Grid.Column="1" />
    </Grid>
</Window>
