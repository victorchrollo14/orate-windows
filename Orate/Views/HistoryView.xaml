<UserControl x:Class="Orate.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="40,36,40,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="History" FontSize="34" FontWeight="Bold" />
                <TextBlock x:Name="CountLabel" Foreground="{StaticResource SecondaryTextBrush}"
                           FontSize="14" Margin="0,6,0,0" />
            </StackPanel>
            <Button x:Name="ClearButton" Content="Clear All" HorizontalAlignment="Right"
                    VerticalAlignment="Top" Click="OnClearAll" />
        </Grid>

        <!-- Empty state -->
        <StackPanel x:Name="EmptyState" Grid.Row="1" VerticalAlignment="Center"
                    HorizontalAlignment="Center" Visibility="Collapsed">
            <TextBlock Text="&#xE720;" FontFamily="Segoe MDL2 Assets" FontSize="40"
                       Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="No transcriptions yet" FontSize="16" Margin="0,14,0,0"
                       Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="Hold your push-to-talk key to record your first one."
                       Foreground="{StaticResource SecondaryTextBrush}" Opacity="0.7"
                       Margin="0,4,0,0" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- List -->
        <ScrollViewer x:Name="ListScroller" Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="List">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1" CornerRadius="10" Padding="18" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{Binding Transcript}" TextWrapping="Wrap" FontSize="14"
                                           LineHeight="20" />
                                <Grid Margin="0,14,0,0">
                                    <TextBlock Text="{Binding Info}" Foreground="{StaticResource SecondaryTextBrush}"
                                               FontSize="12" VerticalAlignment="Center" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="&#xE768;" FontFamily="Segoe MDL2 Assets" Padding="10,6"
                                                ToolTip="Play" Click="OnPlay" />
                                        <Button Content="&#xE8C8;" FontFamily="Segoe MDL2 Assets" Padding="10,6"
                                                Margin="8,0,0,0" ToolTip="Copy" Click="OnCopy" />
                                        <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" Padding="10,6"
                                                Margin="8,0,0,0" ToolTip="Delete" Click="OnDelete" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
