<UserControl x:Class="Orate.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="640" HorizontalAlignment="Left">

            <TextBlock Text="Orate" FontSize="32" FontWeight="Bold" />
            <TextBlock Text="Push-to-talk voice transcription"
                       FontSize="15" Foreground="#888" Margin="0,4,0,24" />

            <Border Background="#11000000" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="How to use" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <TextBlock TextWrapping="Wrap" Foreground="#666" Margin="0,0,0,6">
                        1. Hold your push-to-talk key and speak.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#666" Margin="0,0,0,6">
                        2. Release the key — Orate transcribes and pastes the cleaned text
                        wherever your cursor is.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#666">
                        3. Press Esc while transcribing to cancel.
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Background="#11000000" CornerRadius="8" Padding="20">
                <StackPanel>
                    <TextBlock Text="Current push-to-talk key" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <TextBlock x:Name="HotkeyLabel" FontSize="18" />
                    <TextBlock x:Name="ProviderLabel" Foreground="#888" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
