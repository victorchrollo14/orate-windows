<UserControl x:Class="Orate.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32">

            <!-- Welcome header -->
            <TextBlock Text="Welcome to Orate" FontSize="34" FontWeight="Bold" />
            <TextBlock Margin="0,8,0,24" FontSize="16" TextWrapping="Wrap"
                       Foreground="{StaticResource SecondaryTextBrush}">
                <Run Text="Hold" />
                <Run x:Name="HotkeyInline" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                <Run Text="and speak. Release to transcribe." />
            </TextBlock>

            <!-- Empty state -->
            <StackPanel x:Name="EmptyState" Margin="0,48,0,0" Visibility="Collapsed">
                <TextBlock Text="&#xE720;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                           Foreground="{StaticResource TertiaryTextBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="No transcriptions yet" FontSize="15" FontWeight="SemiBold"
                           Margin="0,12,0,0" Foreground="{StaticResource SecondaryTextBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="EmptyHint" HorizontalAlignment="Center" Margin="0,4,0,0"
                           Foreground="{StaticResource TertiaryTextBrush}" FontSize="13" />
            </StackPanel>

            <!-- Recent transcriptions -->
            <StackPanel x:Name="ListSection">
                <Grid Margin="0,0,0,12">
                    <TextBlock Text="Recent Transcriptions" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="ClearedLabel" Foreground="#30D158" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,10,0" Visibility="Collapsed" />
                        <Button Click="OnClearClick" Padding="12,6" FontSize="13">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Clear" VerticalAlignment="Center" />
                                <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           VerticalAlignment="Center" Margin="7,1,0,0" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <ItemsControl x:Name="List">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="{Binding Transcript}" TextWrapping="Wrap" FontSize="14"
                                               LineHeight="20" />
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Button Style="{StaticResource IconButton}" FontFamily="Segoe MDL2 Assets"
                                                Content="&#xE768;" ToolTip="Play" Click="OnPlay"
                                                Foreground="{StaticResource AccentBrush}" />
                                        <Button Style="{StaticResource IconButton}" FontFamily="Segoe MDL2 Assets"
                                                Content="&#xE8C8;" ToolTip="Copy" Click="OnCopy" Margin="4,0,0,0"
                                                FontSize="13" />
                                        <Border Width="1" Background="{StaticResource CardBorderBrush}"
                                                Margin="10,3" />
                                        <TextBlock Text="{Binding Info}" FontSize="12"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
