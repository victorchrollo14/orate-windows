<UserControl x:Class="Orate.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Orate.Views">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="640" HorizontalAlignment="Left">

            <TextBlock Text="Settings" FontSize="26" FontWeight="Bold" Margin="0,0,0,24" />

            <!-- Provider -->
            <TextBlock Text="Provider" FontWeight="SemiBold" Margin="0,0,0,6" />
            <ComboBox x:Name="ProviderCombo" Width="280" HorizontalAlignment="Left"
                      SelectionChanged="OnProviderChanged">
                <ComboBoxItem Content="Orate Cloud" />
                <ComboBoxItem Content="Google AI Studio" />
                <ComboBoxItem Content="Vertex AI" />
            </ComboBox>

            <!-- API key -->
            <TextBlock Text="API Key" FontWeight="SemiBold" Margin="0,24,0,6" />

            <!-- Saved state: key is hidden; offer to change it -->
            <StackPanel x:Name="KeySavedPanel" Orientation="Horizontal" Visibility="Collapsed">
                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="14,9">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                                   Foreground="{StaticResource AccentBrush}" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="API key saved" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Button Content="Change Key" Margin="10,0,0,0" Click="OnChangeKey" />
            </StackPanel>

            <!-- Edit state: enter / replace the key -->
            <StackPanel x:Name="KeyEditPanel">
                <StackPanel Orientation="Horizontal">
                    <PasswordBox x:Name="KeyBox" Width="360" />
                    <TextBox x:Name="KeyBoxPlain" Width="360" Visibility="Collapsed" />
                    <CheckBox x:Name="ShowKey" Content="Show" VerticalAlignment="Center"
                              Margin="10,0,0,0" Checked="OnToggleShowKey" Unchecked="OnToggleShowKey" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Button Content="Save Key" Padding="16,8" Click="OnSaveKey" Style="{StaticResource AccentButton}" />
                    <Button x:Name="CancelKeyButton" Content="Cancel" Margin="10,0,0,0"
                            Click="OnCancelKey" Visibility="Collapsed" />
                    <TextBlock x:Name="KeyStatus" VerticalAlignment="Center" Margin="12,0,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- Vertex extra config -->
            <StackPanel x:Name="VertexPanel" Visibility="Collapsed" Margin="0,20,0,0">
                <TextBlock Text="Vertex Project ID" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBox x:Name="VertexProject" Width="360" Padding="6" HorizontalAlignment="Left"
                         LostFocus="OnVertexChanged" />
                <TextBlock Text="Vertex Region" FontWeight="SemiBold" Margin="0,14,0,6" />
                <TextBox x:Name="VertexRegion" Width="280" Padding="6" HorizontalAlignment="Left"
                         LostFocus="OnVertexChanged" />
            </StackPanel>

            <!-- Push-to-talk -->
            <TextBlock Text="Push-to-talk Key" FontWeight="SemiBold" Margin="0,28,0,6" />
            <views:HotkeyRecorderControl x:Name="Hotkey" />

            <!-- Custom instructions -->
            <TextBlock Text="Custom Instructions" FontWeight="SemiBold" Margin="0,28,0,6" />
            <TextBox x:Name="CustomInstructions" Height="100" Padding="6"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     LostFocus="OnInstructionsChanged" />

            <!-- Diagnostics -->
            <TextBlock Text="Diagnostics" FontWeight="SemiBold" Margin="0,28,0,6" />
            <StackPanel Orientation="Horizontal">
                <Button Content="Open Log" Padding="14,8" Click="OnOpenLog" />
                <Button Content="Open Log Folder" Padding="14,8" Margin="10,0,0,0" Click="OnOpenLogFolder" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
