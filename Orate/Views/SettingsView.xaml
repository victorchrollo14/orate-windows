<UserControl x:Class="Orate.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Orate.Views">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="640" HorizontalAlignment="Left">

            <TextBlock Text="Settings" FontSize="26" FontWeight="Bold" Margin="0,0,0,24" />

            <!-- Provider -->
            <TextBlock Text="Provider" FontWeight="SemiBold" Margin="0,0,0,6" />
            <ComboBox x:Name="ProviderCombo" Width="280" HorizontalAlignment="Left"
                      SelectionChanged="OnProviderChanged">
                <ComboBoxItem Content="Orate Cloud" />
                <ComboBoxItem Content="Google AI Studio" />
                <ComboBoxItem Content="Vertex AI" />
            </ComboBox>

            <!-- API key -->
            <TextBlock Text="API Key" FontWeight="SemiBold" Margin="0,24,0,6" />
            <StackPanel Orientation="Horizontal">
                <PasswordBox x:Name="KeyBox" Width="360" Padding="6" />
                <TextBox x:Name="KeyBoxPlain" Width="360" Padding="6" Visibility="Collapsed" />
                <CheckBox x:Name="ShowKey" Content="Show" VerticalAlignment="Center"
                          Margin="10,0,0,0" Checked="OnToggleShowKey" Unchecked="OnToggleShowKey" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Button Content="Save Key" Padding="14,8" Click="OnSaveKey" />
                <TextBlock x:Name="KeyStatus" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#888" />
            </StackPanel>

            <!-- Vertex extra config -->
            <StackPanel x:Name="VertexPanel" Visibility="Collapsed" Margin="0,20,0,0">
                <TextBlock Text="Vertex Project ID" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBox x:Name="VertexProject" Width="360" Padding="6" HorizontalAlignment="Left"
                         LostFocus="OnVertexChanged" />
                <TextBlock Text="Vertex Region" FontWeight="SemiBold" Margin="0,14,0,6" />
                <TextBox x:Name="VertexRegion" Width="280" Padding="6" HorizontalAlignment="Left"
                         LostFocus="OnVertexChanged" />
            </StackPanel>

            <!-- Push-to-talk -->
            <TextBlock Text="Push-to-talk Key" FontWeight="SemiBold" Margin="0,28,0,6" />
            <views:HotkeyRecorderControl x:Name="Hotkey" />

            <!-- Custom instructions -->
            <TextBlock Text="Custom Instructions" FontWeight="SemiBold" Margin="0,28,0,6" />
            <TextBox x:Name="CustomInstructions" Height="100" Padding="6"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     LostFocus="OnInstructionsChanged" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
