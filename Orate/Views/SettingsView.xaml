<UserControl x:Class="Orate.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Orate.Views">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="680" HorizontalAlignment="Left">

            <!-- Header -->
            <TextBlock Text="Settings" FontSize="34" FontWeight="Bold" />
            <TextBlock Margin="0,8,0,24" FontSize="16"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="Configure your API credentials and preferences." />

            <!-- Push-to-talk -->
            <TextBlock Text="Push-to-Talk Key" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,6" />
            <TextBlock Margin="0,0,0,10" TextWrapping="Wrap" FontSize="13"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="Hold this key to record, release to transcribe. Click the button below and press a key to change it." />
            <views:HotkeyRecorderControl x:Name="Hotkey" HorizontalAlignment="Left" />

            <!-- Provider -->
            <TextBlock Text="AI Provider" FontWeight="SemiBold" FontSize="15" Margin="0,28,0,6" />
            <TextBlock Margin="0,0,0,10" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}"
                       Text="Choose where to send your audio for transcription." />
            <Border Background="{StaticResource FieldBrush}" BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="2" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="ProviderOrate" Style="{StaticResource Segment}" GroupName="Provider"
                                 Content="Orate Cloud" Checked="OnProviderChanged" />
                    <RadioButton x:Name="ProviderGoogle" Style="{StaticResource Segment}" GroupName="Provider"
                                 Content="Google AI Studio" Checked="OnProviderChanged" />
                    <RadioButton x:Name="ProviderVertex" Style="{StaticResource Segment}" GroupName="Provider"
                                 Content="Vertex AI" Checked="OnProviderChanged" />
                </StackPanel>
            </Border>

            <!-- API key -->
            <TextBlock x:Name="ApiKeyHeader" Text="API Key" FontWeight="SemiBold" FontSize="15" Margin="0,28,0,6" />
            <TextBlock x:Name="ApiKeyHint" Margin="0,0,0,10" TextWrapping="Wrap" FontSize="13"
                       Foreground="{StaticResource SecondaryTextBrush}" />

            <!-- Saved state: key is hidden; offer to change it -->
            <StackPanel x:Name="KeySavedPanel" Orientation="Horizontal" Visibility="Collapsed">
                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="14,9">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                                   Foreground="{StaticResource AccentBrush}" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="API key saved" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Button Content="Change Key" Margin="10,0,0,0" Click="OnChangeKey" />
            </StackPanel>

            <!-- Edit state: enter / replace the key -->
            <StackPanel x:Name="KeyEditPanel">
                <StackPanel Orientation="Horizontal">
                    <PasswordBox x:Name="KeyBox" Width="360" />
                    <TextBox x:Name="KeyBoxPlain" Width="360" Visibility="Collapsed" />
                    <CheckBox x:Name="ShowKey" Content="Show" VerticalAlignment="Center"
                              Margin="10,0,0,0" Checked="OnToggleShowKey" Unchecked="OnToggleShowKey" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Button Content="Save Key" Padding="16,8" Click="OnSaveKey" Style="{StaticResource AccentButton}" />
                    <Button x:Name="CancelKeyButton" Content="Cancel" Margin="10,0,0,0"
                            Click="OnCancelKey" Visibility="Collapsed" />
                    <TextBlock x:Name="KeyStatus" VerticalAlignment="Center" Margin="12,0,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- Vertex extra config -->
            <StackPanel x:Name="VertexPanel" Visibility="Collapsed" Margin="0,20,0,0">
                <TextBlock Text="Vertex Project ID" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBox x:Name="VertexProject" Width="360" Padding="10,7" HorizontalAlignment="Left"
                         LostFocus="OnVertexChanged" />
                <TextBlock Text="Vertex Region" FontWeight="SemiBold" Margin="0,14,0,6" />
                <TextBox x:Name="VertexRegion" Width="280" Padding="10,7" HorizontalAlignment="Left"
                         LostFocus="OnVertexChanged" />
            </StackPanel>

            <!-- Diagnostics -->
            <TextBlock Text="Diagnostics" FontWeight="SemiBold" FontSize="15" Margin="0,28,0,10" />
            <StackPanel Orientation="Horizontal">
                <Button Content="Open Log" Padding="14,8" Click="OnOpenLog" />
                <Button Content="Open Log Folder" Padding="14,8" Margin="10,0,0,0" Click="OnOpenLogFolder" />
            </StackPanel>

            <!-- About / updates -->
            <TextBlock Text="About" FontWeight="SemiBold" FontSize="15" Margin="0,28,0,10" />
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="VersionLabel" Foreground="{StaticResource SecondaryTextBrush}"
                           VerticalAlignment="Center" />
                <Button x:Name="UpdateButton" Content="Check for Updates" Margin="14,0,0,0"
                        Click="OnCheckForUpdates" Style="{StaticResource AccentButton}" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
